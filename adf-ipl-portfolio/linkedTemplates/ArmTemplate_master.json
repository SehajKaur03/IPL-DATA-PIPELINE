{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-ipl-portfolio"
		},
		"SqlServer1_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'SqlServer1'"
		},
		"SqlServer_hl_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'SqlServer_hl'"
		},
		"AzureBlobStorage1_properties_typeProperties_serviceEndpoint": {
			"type": "string",
			"defaultValue": "https://iplstorage2026.blob.core.windows.net/"
		},
		"SqlServer1_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "localhost\\SQLEXPRESS01,1433"
		},
		"SqlServer1_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "ipl-set"
		},
		"SqlServer1_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "crd-srv"
		},
		"SqlServer_hl_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "192.168.10.224"
		},
		"SqlServer_hl_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "player_profile"
		},
		"SqlServer_hl_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sehaj"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-ipl-portfolio_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"SqlServer1_password": {
						"value": "[parameters('SqlServer1_password')]"
					},
					"SqlServer_hl_password": {
						"value": "[parameters('SqlServer_hl_password')]"
					},
					"AzureBlobStorage1_properties_typeProperties_serviceEndpoint": {
						"value": "[parameters('AzureBlobStorage1_properties_typeProperties_serviceEndpoint')]"
					},
					"SqlServer1_properties_typeProperties_server": {
						"value": "[parameters('SqlServer1_properties_typeProperties_server')]"
					},
					"SqlServer1_properties_typeProperties_database": {
						"value": "[parameters('SqlServer1_properties_typeProperties_database')]"
					},
					"SqlServer1_properties_typeProperties_userName": {
						"value": "[parameters('SqlServer1_properties_typeProperties_userName')]"
					},
					"SqlServer_hl_properties_typeProperties_server": {
						"value": "[parameters('SqlServer_hl_properties_typeProperties_server')]"
					},
					"SqlServer_hl_properties_typeProperties_database": {
						"value": "[parameters('SqlServer_hl_properties_typeProperties_database')]"
					},
					"SqlServer_hl_properties_typeProperties_userName": {
						"value": "[parameters('SqlServer_hl_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}